{
  "name": "agent-world",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "AI agents living in a pixel RPG village — Anthropic API + Phaser 3",
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "vite build --config client/vite.config.ts",
    "start": "tsx server/index.ts",
    "typecheck": "tsc -p server/tsconfig.json && tsc -p client/tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "phaser": "^3.87.0",
    "tsx": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
