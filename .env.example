# Anthropic API key — required for agents to think. Without it they wander aimlessly.
ANTHROPIC_API_KEY=

# Simulation tick length in milliseconds (1 tick = one movement step)
TICK_INTERVAL_MS=3000

# Hard cap on Anthropic API calls per minute (cost guardrail)
MAX_API_CALLS_PER_MIN=10

# Autonomous thinking. false (default) = villagers roam for FREE and only call
# the API when you chat to them or send Tessa an intake (no idle token spend).
# true = the full show: agents think and strike up conversations on their own.
AUTO_THINK=false

# Model used for agent decisions and conversations
MODEL=claude-haiku-4-5-20251001

# API/WebSocket server port
API_PORT=3001

# --- Armada intake agent (Tessa) ---
# Reads an intake photo, fills the Welcome Letter + Notice to Insurance, and
# emails them. The vision read needs ANTHROPIC_API_KEY (above).

# Model used to read intake photos. Defaults to claude-opus-4-8 (best OCR on
# phone photos / handwriting). Set to claude-haiku-4-5 if your key lacks Opus access.
INTAKE_MODEL=claude-opus-4-8

# Resend API key — required to actually SEND the drafted documents by email.
# Without it, Tessa still drafts both documents (the run just isn't emailed).
RESEND_API_KEY=

# Recipient of the drafted documents, and the From address. The From domain
# must be verified in Resend (armadapa.com).
INTAKE_TO_EMAIL=Sele@armadapa.com
INTAKE_FROM_EMAIL=Armada Intake <claims@armadapa.com>
